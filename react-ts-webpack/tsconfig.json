{
    "compilerOptions": {
      "allowSyntheticDefaultImports": true,
      "jsx": "react",
      "module": "commonjs",
      "noImplicitAny": true,
      "outDir": "./build/",
      "preserveConstEnums": true,
      "removeComments": true,
      "sourceMap": true,
      "target": "es6",
      "baseUrl": ".",
      "paths": {
        "~/*": ["src/*"]
      },
      "rootDir": "src"
    },
    "include": [
      "./src/**/**/*"
    ],
  "exclude": ["node_modules", "build", "scripts", "acceptance-tests", "webpack", "jest", "src/setupTests.ts", "config","**/*.test.tsx","**/*.test.ts"],
  "typeRoots": ["node_modules/@types", "src/types"]
}
