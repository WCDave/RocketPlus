{
    "compilerOptions": {
      "allowSyntheticDefaultImports": true,
      "jsx": "react",
      "module": "commonjs",
      "noImplicitAny": true,
      "outDir": "./build/",
      "preserveConstEnums": true,
      "removeComments": true,
      "sourceMap": true,
      "target": "es6",
      "baseUrl": ".",
      "paths": {
        "~/*": ["src/*"]
      },
      "rootDir": "src"
    },
    "include": [
      "./src/**/**/*"
    ],
  "exclude": ["**/*.test.tsx","**/*.test.ts"]
}
